<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GeoMaster Brasil</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:linear-gradient(135deg,#001f4d,#0059b3,#00a2ff);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
overflow:hidden;
}

.game{
width:100%;
max-width:850px;
background:rgba(255,255,255,0.10);
backdrop-filter:blur(15px);
border-radius:30px;
padding:30px;
color:white;
box-shadow:0 15px 45px rgba(0,0,0,0.5);
animation:entrada .6s ease;
}

@keyframes entrada{
from{
opacity:0;
transform:translateY(40px);
}
to{
opacity:1;
transform:translateY(0);
}
}

h1{
text-align:center;
font-size:45px;
margin-bottom:20px;
}

.sub{
text-align:center;
font-size:20px;
margin-bottom:25px;
}

button{
border:none;
border-radius:18px;
padding:15px;
font-size:18px;
font-weight:bold;
cursor:pointer;
transition:.3s;
width:100%;
}

button:hover{
transform:scale(1.03);
}

.jogar{
background:#00c853;
color:white;
}

.menuBtn{
background:#ff9800;
color:white;
width:auto;
padding:10px 15px;
font-size:15px;
}

.info{
display:flex;
justify-content:space-between;
align-items:center;
flex-wrap:wrap;
gap:10px;
margin-bottom:20px;
font-weight:bold;
font-size:17px;
}

.nivel{
text-align:center;
font-size:24px;
font-weight:bold;
margin-bottom:20px;
}

.pergunta{
background:rgba(255,255,255,0.15);
padding:25px;
border-radius:22px;
font-size:24px;
font-weight:bold;
text-align:center;
margin-bottom:20px;
box-shadow:0 8px 20px rgba(0,0,0,0.3);
}

.opcao{
background:linear-gradient(to right,#1565c0,#00bcd4);
color:white;
margin-top:12px;
}

.opcao:disabled{
opacity:0.6;
cursor:not-allowed;
}

.mensagem{
margin-top:20px;
font-size:24px;
font-weight:bold;
text-align:center;
}

.painel{
margin-top:25px;
background:rgba(255,255,255,0.12);
padding:20px;
border-radius:18px;
text-align:center;
font-size:18px;
font-weight:bold;
line-height:1.8;
}

.reiniciar{
background:#ffee58;
color:black;
margin-top:20px;
}

</style>
</head>

<body>

<div class="game">

<!-- CAPA -->

<div id="inicio">

<h1>🌍 GeoMaster Brasil</h1>

<div class="sub">
50 perguntas únicas e embaralhadas de Geografia
</div>

<button class="jogar" onclick="iniciarJogo()">
▶ Jogar
</button>

</div>

<!-- QUIZ -->

<div id="quiz" style="display:none;">

<div class="info">

<span id="pontos">🌟 0</span>

<span id="acertos">✅ 0</span>

<span id="erros">❌ 0</span>

<span id="vidas">❤️ 10</span>

<button class="menuBtn" onclick="voltarCapa()">
🏠 Sair
</button>

</div>

<div class="nivel" id="nivel">
🟢 Nível Fácil
</div>

<div class="pergunta" id="pergunta"></div>

<div id="opcoes"></div>

<div class="mensagem" id="mensagem"></div>

<div class="painel">

<div id="painelAcertos">
✅ Acertos: 0
</div>

<div id="painelErros">
❌ Erros: 0
</div>

<div id="painelPontos">
🌟 Pontuação: 0
</div>

</div>

</div>

<!-- FINAL -->

<div id="fim" style="display:none;">

<h1>🏆 Fim de Jogo</h1>

<div class="painel" id="resultado"></div>

<button class="reiniciar" onclick="reiniciarJogo()">
🔄 Jogar Novamente
</button>

</div>

</div>

<script>

/* ---------------- EMBARALHAR ---------------- */

function embaralhar(lista){

for(let i=lista.length-1;i>0;i--){

const j=Math.floor(Math.random()*(i+1));

[lista[i],lista[j]]=[lista[j],lista[i]];

}

}

/* ---------------- PERGUNTAS ---------------- */

const faceis = [

{p:"Qual é a capital do Brasil?",o:["Brasília","Rio","São Paulo","Salvador"],r:"Brasília"},
{p:"Qual país possui a Torre Eiffel?",o:["França","Itália","Portugal","Canadá"],r:"França"},
{p:"Qual é o maior oceano?",o:["Pacífico","Atlântico","Índico","Ártico"],r:"Pacífico"},
{p:"Qual continente fica o Brasil?",o:["América do Sul","Europa","Ásia","África"],r:"América do Sul"},
{p:"Qual é a capital da França?",o:["Paris","Roma","Madri","Lisboa"],r:"Paris"},
{p:"Qual país possui a Muralha da China?",o:["China","Japão","Índia","Coreia"],r:"China"},
{p:"Qual oceano banha o Brasil?",o:["Atlântico","Pacífico","Ártico","Índico"],r:"Atlântico"},
{p:"Qual país é conhecido pelo tango?",o:["Argentina","Brasil","Chile","Uruguai"],r:"Argentina"},
{p:"Qual linha divide norte e sul?",o:["Equador","Greenwich","Capricórnio","Câncer"],r:"Equador"},
{p:"Qual é a capital do Japão?",o:["Tóquio","Pequim","Seul","Bangkok"],r:"Tóquio"},
{p:"Qual clima predomina na Amazônia?",o:["Equatorial","Polar","Desértico","Temperado"],r:"Equatorial"},
{p:"Qual continente fica o Egito?",o:["África","Europa","Ásia","Oceania"],r:"África"},
{p:"Qual é o maior continente?",o:["Ásia","Europa","África","Oceania"],r:"Ásia"},
{p:"Qual relevo possui grandes elevações?",o:["Montanha","Vale","Planície","Depressão"],r:"Montanha"},
{p:"Qual país possui formato de bota?",o:["Itália","Chile","Peru","México"],r:"Itália"},
{p:"Qual é a capital da Argentina?",o:["Buenos Aires","Lima","Bogotá","Santiago"],r:"Buenos Aires"}

];

const medias = [

{p:"Qual cordilheira fica na América do Sul?",o:["Andes","Alpes","Himalaia","Rochosas"],r:"Andes"},
{p:"Qual é o maior rio do mundo em volume?",o:["Amazonas","Nilo","Yangtzé","Mississipi"],r:"Amazonas"},
{p:"Qual é a capital da Alemanha?",o:["Berlim","Praga","Viena","Zurique"],r:"Berlim"},
{p:"Qual clima possui pouca chuva?",o:["Semiárido","Polar","Equatorial","Temperado"],r:"Semiárido"},
{p:"Qual rio passa pelo Egito?",o:["Nilo","Amazonas","Danúbio","Yangtzé"],r:"Nilo"},
{p:"Qual deserto fica na África?",o:["Saara","Atacama","Gobi","Mojave"],r:"Saara"},
{p:"Qual país abriga Machu Picchu?",o:["Peru","Chile","México","Brasil"],r:"Peru"},
{p:"Qual é a capital da Itália?",o:["Roma","Milão","Turim","Nápoles"],r:"Roma"},
{p:"Qual linha divide leste e oeste?",o:["Greenwich","Equador","Capricórnio","Câncer"],r:"Greenwich"},
{p:"Qual relevo é plano?",o:["Planície","Montanha","Vale","Cordilheira"],r:"Planície"},
{p:"Qual país possui mais população?",o:["Índia","Brasil","Canadá","México"],r:"Índia"},
{p:"Qual é a capital de Portugal?",o:["Lisboa","Porto","Faro","Coimbra"],r:"Lisboa"},
{p:"Qual clima possui temperaturas muito baixas?",o:["Polar","Tropical","Equatorial","Semiárido"],r:"Polar"},
{p:"Qual oceano fica entre América e Europa?",o:["Atlântico","Pacífico","Índico","Ártico"],r:"Atlântico"},
{p:"Qual mapa mostra divisões políticas?",o:["Mapa político","Mapa físico","Mapa climático","Mapa econômico"],r:"Mapa político"},
{p:"Qual é o menor continente?",o:["Oceania","Europa","África","América"],r:"Oceania"},
{p:"Qual é a capital da Rússia?",o:["Moscou","Kiev","Minsk","Varsóvia"],r:"Moscou"}

];

const dificeis = [

{p:"Qual deserto é o mais seco do mundo?",o:["Atacama","Saara","Gobi","Kalahari"],r:"Atacama"},
{p:"Qual é a capital da Mongólia?",o:["Ulan Bator","Astana","Tashkent","Pequim"],r:"Ulan Bator"},
{p:"Qual estreito separa Europa da África?",o:["Gibraltar","Bering","Ormuz","Magalhães"],r:"Gibraltar"},
{p:"Qual é a montanha mais alta do mundo?",o:["Everest","K2","Aconcágua","Monte Branco"],r:"Everest"},
{p:"Qual é a capital da Islândia?",o:["Reykjavik","Oslo","Helsinque","Copenhague"],r:"Reykjavik"},
{p:"Qual país possui mais fusos horários?",o:["França","Rússia","Estados Unidos","China"],r:"França"},
{p:"Qual é o oceano mais frio?",o:["Ártico","Pacífico","Atlântico","Índico"],r:"Ártico"},
{p:"Qual relevo é uma área rebaixada?",o:["Depressão","Planalto","Montanha","Vale"],r:"Depressão"},
{p:"Qual é a capital da Nova Zelândia?",o:["Wellington","Auckland","Sydney","Canberra"],r:"Wellington"},
{p:"Qual país possui maior território?",o:["Rússia","Canadá","China","Brasil"],r:"Rússia"},
{p:"Qual corrente marítima aquece a Europa?",o:["Corrente do Golfo","Humboldt","El Niño","La Niña"],r:"Corrente do Golfo"},
{p:"Qual continente possui mais países?",o:["África","Europa","Ásia","América"],r:"África"},
{p:"Qual é a capital do Cazaquistão?",o:["Astana","Moscou","Kiev","Tbilisi"],r:"Astana"},
{p:"Qual clima é típico de desertos?",o:["Desértico","Polar","Temperado","Equatorial"],r:"Desértico"},
{p:"Qual relevo é elevado e relativamente plano?",o:["Planalto","Vale","Montanha","Depressão"],r:"Planalto"},
{p:"Qual oceano banha a Índia?",o:["Índico","Pacífico","Atlântico","Ártico"],r:"Índico"},
{p:"Qual país é chamado Terra do Sol Nascente?",o:["Japão","China","Índia","Tailândia"],r:"Japão"}

];

embaralhar(faceis);
embaralhar(medias);
embaralhar(dificeis);

/* ---------------- VARIÁVEIS ---------------- */

let perguntasAtual=faceis;
let nivelAtual="facil";

let indice=0;
let pontos=0;
let acertos=0;
let erros=0;
let vidas=10;

let bloqueado=false;

/* ---------------- INICIAR ---------------- */

function iniciarJogo(){

document.getElementById("inicio").style.display="none";

document.getElementById("quiz").style.display="block";

mostrarPergunta();

}

/* ---------------- MOSTRAR ---------------- */

function mostrarPergunta(){

if(vidas<=0){

finalizarJogo();
return;

}

if(indice>=perguntasAtual.length){

trocarNivel();
return;

}

bloqueado=false;

const atual=perguntasAtual[indice];

document.getElementById("pergunta").innerText=
atual.p;

const opcoesDiv=document.getElementById("opcoes");

opcoesDiv.innerHTML="";

const opcoes=[...atual.o];

embaralhar(opcoes);

opcoes.forEach(opcao=>{

const btn=document.createElement("button");

btn.className="opcao";

btn.innerText=opcao;

btn.onclick=()=>responder(opcao);

opcoesDiv.appendChild(btn);

});

}

/* ---------------- RESPONDER ---------------- */

function responder(opcao){

if(bloqueado) return;

bloqueado=true;

document.querySelectorAll(".opcao")
.forEach(btn=>btn.disabled=true);

const atual=perguntasAtual[indice];

if(opcao===atual.r){

pontos+=10;
acertos++;

document.getElementById("mensagem").innerText=
"✅ Resposta Correta!";

}else{

vidas--;
erros++;

document.getElementById("mensagem").innerText=
"❌ Resposta Errada!";

}

atualizarPainel();

indice++;

setTimeout(()=>{

document.getElementById("mensagem").innerText="";

mostrarPergunta();

},1200);

}

/* ---------------- PAINEL ---------------- */

function atualizarPainel(){

document.getElementById("pontos").innerText=
"🌟 "+pontos;

document.getElementById("acertos").innerText=
"✅ "+acertos;

document.getElementById("erros").innerText=
"❌ "+erros;

document.getElementById("vidas").innerText=
"❤️ "+vidas;

document.getElementById("painelAcertos").innerText=
"✅ Acertos: "+acertos;

document.getElementById("painelErros").innerText=
"❌ Erros: "+erros;

document.getElementById("painelPontos").innerText=
"🌟 Pontuação: "+pontos;

}

/* ---------------- TROCAR NÍVEL ---------------- */

function trocarNivel(){

if(nivelAtual==="facil"){

nivelAtual="medio";

perguntasAtual=medias;

indice=0;

document.getElementById("nivel").innerText=
"🟠 Nível Médio";

alert("🎉 Você passou para o nível MÉDIO!");

mostrarPergunta();

}

else if(nivelAtual==="medio"){

nivelAtual="dificil";

perguntasAtual=dificeis;

indice=0;

document.getElementById("nivel").innerText=
"🔴 Nível Difícil";

alert("🔥 Você passou para o nível DIFÍCIL!");

mostrarPergunta();

}

else{

finalizarJogo();

}

}

/* ---------------- SAIR ---------------- */

function voltarCapa(){

document.getElementById("quiz").style.display="none";

document.getElementById("inicio").style.display="block";

}

/* ---------------- FINAL ---------------- */

function finalizarJogo(){

document.getElementById("quiz").style.display="none";

document.getElementById("fim").style.display="block";

document.getElementById("resultado").innerHTML=

"🎉 Parabéns!<br><br>"+
"🌟 Pontos: "+pontos+"<br>"+
"✅ Acertos: "+acertos+"<br>"+
"❌ Erros: "+erros;

}

/* ---------------- REINICIAR ---------------- */

function reiniciarJogo(){

nivelAtual="facil";

perguntasAtual=faceis;

indice=0;

pontos=0;

acertos=0;

erros=0;

vidas=10;

embaralhar(faceis);
embaralhar(medias);
embaralhar(dificeis);

document.getElementById("fim").style.display="none";

document.getElementById("quiz").style.display="block";

document.getElementById("nivel").innerText=
"🟢 Nível Fácil";

atualizarPainel();

mostrarPergunta();

}

</script>

</body>
</html>
